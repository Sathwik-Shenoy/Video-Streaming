# ─── Server Configuration ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── HTTPS (set to 'true' to enable) ──────────────────────────────────────
USE_HTTPS=false
SSL_CERT_PATH=./certs/cert.pem
SSL_KEY_PATH=./certs/key.pem

# ─── CORS ─────────────────────────────────────────────────────────────────
# Comma-separated origins, or '*' for all
ALLOWED_ORIGIN=*

# ─── TURN Server (REQUIRED for cross-network connectivity) ────────────────
# Example: turn:turn.yourdomain.com:3478
TURN_URL=
TURN_USERNAME=
TURN_PASSWORD=

# ─── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_MAX=120
